{
  "name": "hrrr-map",
  "version": "0.1.0",
  "description": "HRRR 48-hour smoke + rain forecast viewer (static SPA)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "record-fixtures": "node --experimental-strip-types scripts/record-fixtures.ts",
    "fetch-grib-fixtures": "node --experimental-strip-types scripts/fetch-grib-fixtures.ts"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:41729/git/samn/hrrrr-map"
  },
  "dependencies": {
    "icechunk-js": "0.6.0",
    "maplibre-gl": "5.24.0",
    "zarrita": "0.7.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@mattnucc/gribberish": "1.5.0",
    "@playwright/test": "1.56.0",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "private": true,
  "type": "module"
}
